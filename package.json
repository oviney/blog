{
  "name": "economist-blog-v5",
  "version": "1.0.0",
  "description": "Software engineering insights on quality, testing, and AI - written in The Economist's signature style.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "npm run test:visual && npm run test:a11y && npm run test:lighthouse && npm run test:playwright",
    "test:visual:reference": "npx backstop reference",
    "test:visual": "npx backstop test",
    "test:visual:approve": "npx backstop approve",
    "test:a11y": "pa11y-ci",
    "test:lighthouse": "lhci autorun",
    "test:playwright": "npx playwright test",
    "test:playwright:headed": "npx playwright test --headed",
    "test:playwright:debug": "npx playwright test --debug",
    "test:playwright:ui": "npx playwright test --ui",
    "test:playwright:shard1": "PLAYWRIGHT_SHARD=1/3 PLAYWRIGHT_GREP='@REQ-NAV-01|@REQ-NAV-02' npx playwright test",
    "test:playwright:shard2": "PLAYWRIGHT_SHARD=2/3 PLAYWRIGHT_GREP='@REQ-CONTENT-01|@REQ-CONTENT-02|@REQ-LINKS-01' npx playwright test",
    "test:playwright:shard3": "PLAYWRIGHT_SHARD=3/3 PLAYWRIGHT_GREP='@REQ-A11Y-02|@REQ-VISUAL-01|@REQ-PERF-01' npx playwright test",
    "quality:report": "node scripts/generate-quality-report.js",
    "test:agents:plan": "npx playwright plan --output=specs/",
    "test:agents:generate": "npx playwright generate --from-specs=specs/",
    "test:agents:heal": "npx playwright heal --interactive",
    "test:security": "npm audit --audit-level=moderate",
    "pretest": "echo 'Ensure Jekyll is running on port 4000 before running tests'",
    "monitor:healing": "node scripts/healing-monitor.js",
    "analyze:healing-trends": "node scripts/analyze-healing-trends.js",
    "analyze:failures": "node scripts/analyze-failures.js",
    "alert:healing-degradation": "node scripts/check-healing-degradation.js",
    "alert:system": "node scripts/alert-system.js",
    "dashboard": "echo 'Dashboard available at: https://oviney.github.io/blog/dashboard/' && npx serve dashboard --port 8081",
    "dashboard:dev": "npx serve dashboard --port 8081",
    "monitoring:full": "npm run monitor:healing && npm run alert:system",
    "deploy:dashboard": "echo 'Dashboard automatically available at: https://oviney.github.io/blog/dashboard/' && echo 'Data updates by pushing to main branch or running: gh workflow run healing-monitor.yml'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oviney/blog.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/oviney/blog/issues"
  },
  "homepage": "https://github.com/oviney/blog#readme",
  "overrides": {
    "lodash": "^4.18.1",
    "tmp": ">=0.2.3",
    "basic-ftp": "5.3.0",
    "@lhci/cli": {
      "uuid": "npm:@smithy/uuid@^1.1.2"
    }
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "backstopjs": "^6.3.25",
    "lighthouse": "^13.2.0",
    "pa11y-ci": "^4.1.0"
  }
}
